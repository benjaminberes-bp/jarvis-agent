# Honcho .env (self-hosted Jarvis). Copier vers /opt/honcho-stack/.env.
# La plupart de la config est dans config.toml (committable). Ici : secrets +
# overrides d'env. NE JAMAIS committer le .env rempli.

LOG_LEVEL=INFO

# === SECRET — à coller sur le serveur, jamais committé ===
# Clé Anthropic Jarvis. Sert au deriver/dialectic/summary/dream
# (modèle léger claude-haiku-4-5, défini dans config.toml).
LLM_ANTHROPIC_API_KEY=__COLLER_LA_CLE_ANTHROPIC_ICI__

# === Embeddings Ollama (clé factice — Ollama l'ignore) ===
OLLAMA_DUMMY_KEY=ollama

# Note : DB_CONNECTION_URI et CACHE_URL sont déjà injectés par le
# docker-compose.yml officiel (service database / redis) — inutile ici.
# AUTH désactivée via config.toml ([auth] USE_AUTH=false) : api non exposée
# publiquement, jointe uniquement par le conteneur `jarvis` sur le réseau honcho-net.
